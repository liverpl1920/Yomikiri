<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "Yomikiri | 積読を消化する技術" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "積読に賞味期限を設定し、今日のノルマを自動計算。読書を行動に変えるアプリ。" %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <main>
      <%= yield %>
    </main>
  </body>
</html>
